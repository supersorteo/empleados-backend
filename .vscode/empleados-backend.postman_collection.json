{
  "info": {
    "name": "Empleados Backend",
    "_postman_id": "462e595f-0785-4e0b-a489-4228d4a93d35",
    "description": "Auth + Employees CRUD",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "employeeId", "value": "1" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin123*\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('token', json.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Credentials",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/auth/credentials"
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/auth/change-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"Admin123*\",\n  \"newPassword\": \"NuevaClave123*\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Employees (ADMIN)",
      "item": [
        {
          "name": "Create Employee",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/employees",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Juan Perez\",\n  \"username\": \"jperez\",\n  \"email\": \"juan@empresa.com\",\n  \"dni\": \"12345678\",\n  \"password\": \"ClaveSegura123*\",\n  \"role\": \"EMPLOYEE\",\n  \"shiftStart\": \"08:00:00\",\n  \"toleranceMinutes\": 10,\n  \"maxPauseMinutes\": 45\n}"
            }
          }
        },
        {
          "name": "List Employees",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/employees?page=0&size=20"
          }
        },
        {
          "name": "Get Employee By Id",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/employees/{{employeeId}}"
          }
        },
        {
          "name": "Update Employee",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/employees/{{employeeId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Juan Perez Actualizado\",\n  \"username\": \"jperez\",\n  \"email\": \"juan.perez@empresa.com\",\n  \"dni\": \"12345678\",\n  \"role\": \"SUPERVISOR\",\n  \"shiftStart\": \"09:00:00\",\n  \"toleranceMinutes\": 15,\n  \"maxPauseMinutes\": 60,\n  \"newPassword\": \"NuevaClave123*\"\n}"
            }
          }
        },
        {
          "name": "Deactivate Employee",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/employees/{{employeeId}}"
          }
        }
      ]
    },
    {
      "name": "Users (ADMIN)",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/users?page=0&size=20"
          }
        },
        {
          "name": "Get User By Id",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/users/{{employeeId}}"
          }
        }
      ]
    }
  ]
}
